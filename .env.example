DISCORD_TOKEN=YOUR_BOT_TOKEN
GUILD_ID=123456789012345678
WATCH_USER_ID=123456789012345678
MENTION_USER_ID=123456789012345678
INCIDENT_CHANNEL_ID=234567890123456789
DEBOUNCE_MS=15000

# TVTest HTTP Plugin の URL (省略時は TV 機能無効)
# TVTest が別 PC にある場合は http://<WindowsのIP>:40152 に設定
TVTEST_API_URL=http://<YOUR-TVTEST-IP>:40152

# チャンネルスキャン対象の BonDriver をカンマ区切りで指定
# 省略時は起動時に現在ロード中のドライバのみをスキャンする
TVTEST_BON_DRIVERS=BonDriver_Proxy_T.dll,BonDriver_Proxy_S.dll

# BonDriver 切替後に待機する時間 (ms)
# TS ドロップや選局エラーが出る場合は 1500〜3000 くらいまで増やして調整
TVTEST_POST_DRIVER_SWITCH_DELAY_MS=2000

# チャンネル変更後に待機する時間 (ms)
# ドライバ復帰後の再選局が不安定な場合は少し増やす
TVTEST_POST_CHANNEL_CHANGE_DELAY_MS=500
